<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fonte base: Segoe UI 13 -->
    <FontFamily x:Key="FontBase">Segoe UI</FontFamily>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="FontSizeBase">13</sys:Double>

    <!-- Fonte técnica: Consolas 12 -->
    <FontFamily x:Key="FontMono">Consolas</FontFamily>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="FontSizeMono">12</sys:Double>

</ResourceDictionary>
