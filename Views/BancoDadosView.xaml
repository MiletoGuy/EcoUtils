<UserControl x:Class="EcoUtils.Views.BancoDadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:views="clr-namespace:EcoUtils.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- cabeçalho + toolbar -->
            <RowDefinition Height="*"/>    <!-- conteúdo principal -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             Cabeçalho + Toolbar
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid Height="46">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- título -->
                    <ColumnDefinition Width="24"/>   <!-- separador -->
                    <ColumnDefinition Width="Auto"/> <!-- seletor de banco -->
                    <ColumnDefinition Width="*"/>    <!-- spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- indicador de transação -->
                    <ColumnDefinition Width="Auto"/> <!-- commit -->
                    <ColumnDefinition Width="Auto"/> <!-- rollback -->
                    <ColumnDefinition Width="Auto"/> <!-- sql livre -->
                </Grid.ColumnDefinitions>

                <!-- Título -->
                <TextBlock Grid.Column="0"
                           Text="Banco de Dados"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="15"
                           VerticalAlignment="Center"/>

                <!-- Seletor de banco ativo + status de conexão -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <ComboBox ItemsSource="{Binding BancosDisponiveis}"
                              SelectedItem="{Binding BancoSelecionado}"
                              DisplayMemberPath="NomeCompleto"
                              MinWidth="160"
                              VerticalAlignment="Center">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Background"      Value="{StaticResource InputBackground}"/>
                                <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                                <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontFamily"      Value="{StaticResource FontBase}"/>
                                <Setter Property="FontSize"        Value="{StaticResource FontSizeBase}"/>
                                <Setter Property="Padding"         Value="8,4"/>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <!-- Ponto de status de conexão -->
                    <Ellipse Width="8" Height="8"
                             Margin="10,0,0,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextDisabled}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConexaoOk}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource StatusSuccess}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConexaoErro}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource StatusError}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConexaoConectando}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource StatusWarning}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Text="{Binding TextoStatusConexao}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Indicador de transação pendente -->
                <Border Grid.Column="4"
                        Margin="0,0,12,0"
                        Padding="8,3"
                        CornerRadius="3"
                        VerticalAlignment="Center"
                        Background="#33ce9178"
                        Visibility="{Binding TransacaoPendente, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="⚠ transação aberta"
                               Foreground="{StaticResource StatusWarning}"
                               FontSize="11"/>
                </Border>

                <!-- Commit -->
                <Button Grid.Column="5"
                        Command="{Binding CommitCommand}"
                        Style="{StaticResource ButtonSecondary}"
                        Padding="12,5"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        ToolTip="Confirmar transação (Commit)"
                        IsEnabled="{Binding TransacaoPendente}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Margin="0,0,5,0"
                                   Foreground="{StaticResource StatusSuccess}"/>
                        <TextBlock Text="Commit"/>
                    </StackPanel>
                </Button>

                <!-- Rollback -->
                <Button Grid.Column="6"
                        Command="{Binding RollbackCommand}"
                        Style="{StaticResource ButtonSecondary}"
                        Padding="12,5"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        ToolTip="Desfazer transação (Rollback)"
                        IsEnabled="{Binding TransacaoPendente}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↺" Margin="0,0,5,0"
                                   Foreground="{StaticResource StatusError}"/>
                        <TextBlock Text="Rollback"/>
                    </StackPanel>
                </Button>

                <!-- SQL Livre -->
                <Button Grid.Column="7"
                        Command="{Binding AbrirSqlLivreCommand}"
                        Style="{StaticResource ButtonIcon}"
                        Width="32" Height="32"
                        VerticalAlignment="Center"
                        ToolTip="Abrir executor SQL livre">
                    <TextBlock Text="⌨" FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             Área principal
        ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Biblioteca de SQLs (padrão) -->
            <views:SqlLibraryView DataContext="{Binding SqlLibraryVM}"
                                  Visibility="{Binding SqlLivreAberto, Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Flyout do executor SQL livre -->
            <views:SqlLivreView DataContext="{Binding SqlLivreVM}"
                                Visibility="{Binding SqlLivreAberto, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>
    </Grid>
</UserControl>
