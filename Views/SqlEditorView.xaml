<UserControl x:Class="EcoUtils.Views.SqlEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:vm="clr-namespace:EcoUtils.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- título -->
            <RowDefinition Height="Auto"/>  <!-- banner fork -->
            <RowDefinition Height="*"/>     <!-- form fields + editor -->
            <RowDefinition Height="Auto"/>  <!-- action bar -->
        </Grid.RowDefinitions>

        <!-- Título -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="{Binding Titulo}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Banner: aviso de cópia de built-in -->
        <Border Grid.Row="1"
                Visibility="{Binding MostrarAvisoCopia, Converter={StaticResource BoolToVisibility}}"
                Background="#22ce9178"
                BorderBrush="{StaticResource StatusWarning}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <TextBlock Text="Esta consulta é baseada em uma SQL built-in. A cópia será salva na sua biblioteca pessoal."
                       Foreground="{StaticResource StatusWarning}"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Formulário + editor -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12,16,8">

                <!-- Nome -->
                <TextBlock Text="Nome *"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <!-- Categoria -->
                <TextBlock Text="Categoria *"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding CategoriasDisponiveis}"
                          Text="{Binding Categoria, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          Margin="0,0,0,12">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background"      Value="{StaticResource InputBackground}"/>
                            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                            <Setter Property="BorderBrush"     Value="{StaticResource PanelBorder}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontFamily"      Value="{StaticResource FontBase}"/>
                            <Setter Property="FontSize"        Value="{StaticResource FontSizeBase}"/>
                            <Setter Property="Padding"         Value="8,4"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <!-- Descrição -->
                <TextBlock Text="Descrição"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         MaxHeight="80"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12"/>

                <!-- SQL -->
                <TextBlock Text="SQL *"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Margin="0,0,0,4"/>

                <!-- AvalonEdit — Text binding via code-behind -->
                <avalonedit:TextEditor x:Name="EditorSql"
                                       ShowLineNumbers="True"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="{StaticResource FontSizeMono}"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       Height="220"
                                       Margin="0,0,0,12"
                                       Background="{StaticResource AppBackground}"
                                       Foreground="{StaticResource TextPrimary}"
                                       LineNumbersForeground="{StaticResource TextSecondary}"
                                       WordWrap="False"/>

                <!-- Parâmetros -->
                <TextBlock Text="Parâmetros"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ItemsControl ItemsSource="{Binding Parametros}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SqlParameterEditItem}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>   <!-- nome -->
                                    <ColumnDefinition Width="90"/>  <!-- tipo -->
                                    <ColumnDefinition Width="*"/>   <!-- descrição -->
                                    <ColumnDefinition Width="28"/>  <!-- remover -->
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource FontMono}"
                                         FontSize="{StaticResource FontSizeMono}"
                                         Margin="0,0,6,0"/>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Source={x:Static vm:SqlParameterEditItem.TodosTipos}}"
                                          SelectedItem="{Binding Tipo}"
                                          Margin="0,0,6,0">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Background"      Value="{StaticResource InputBackground}"/>
                                            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource PanelBorder}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="FontFamily"      Value="{StaticResource FontBase}"/>
                                            <Setter Property="FontSize"        Value="{StaticResource FontSizeBase}"/>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>

                                <TextBox Grid.Column="2"
                                         Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,6,0"/>

                                <Button Grid.Column="3"
                                        Command="{Binding DataContext.RemoverParametroCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ButtonDanger}"
                                        Width="28" Height="28"
                                        Padding="0"
                                        ToolTip="Remover parâmetro">
                                    <TextBlock Text="✕" FontSize="11" HorizontalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Botão + Adicionar parâmetro -->
                <Button Command="{Binding AdicionarParametroCommand}"
                        Style="{StaticResource ButtonSecondary}"
                        HorizontalAlignment="Left"
                        Padding="10,4"
                        Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" Margin="0,0,6,0" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Adicionar parâmetro"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>

        <!-- Action bar -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding SalvarCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        Padding="16,6"
                        Margin="0,0,8,0"
                        Content="Salvar"/>
                <Button Command="{Binding CancelarCommand}"
                        Style="{StaticResource ButtonSecondary}"
                        Padding="16,6"
                        Content="Cancelar"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
