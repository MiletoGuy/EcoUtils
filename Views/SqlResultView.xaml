<UserControl x:Class="EcoUtils.Views.SqlResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <!-- DataGrid dark theme ─────────────────────────────────── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"                Value="{StaticResource AppBackground}"/>
            <Setter Property="Foreground"                Value="{StaticResource TextPrimary}"/>
            <Setter Property="GridLinesVisibility"       Value="All"/>
            <Setter Property="HorizontalGridLinesBrush"  Value="{StaticResource PanelBorder}"/>
            <Setter Property="VerticalGridLinesBrush"    Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderBrush"               Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="RowBackground"             Value="Transparent"/>
            <Setter Property="AlternatingRowBackground"  Value="{StaticResource TableRowAlternate}"/>
            <Setter Property="RowHeaderWidth"            Value="0"/>
            <Setter Property="ColumnHeaderHeight"        Value="28"/>
            <Setter Property="IsReadOnly"                Value="True"/>
            <Setter Property="SelectionMode"             Value="Extended"/>
            <Setter Property="SelectionUnit"             Value="Cell"/>
            <Setter Property="CanUserResizeRows"         Value="False"/>
            <Setter Property="EnableRowVirtualization"   Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing"      Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode"  Value="Recycling"/>
            <Setter Property="ClipboardCopyMode"         Value="IncludeHeader"/>
            <Setter Property="FrozenColumnCount"         Value="0"/>
            <Setter Property="AutoGenerateColumns"       Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"                Value="{StaticResource TableHeaderBackground}"/>
            <Setter Property="Foreground"                Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontFamily"                Value="{StaticResource FontBase}"/>
            <Setter Property="FontSize"                  Value="11"/>
            <Setter Property="Padding"                   Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush"               Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness"           Value="0,0,1,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"/>
                                <!-- Sort arrow -->
                                <Path x:Name="SortArrow"
                                      Grid.Column="1"
                                      Width="7" Height="5"
                                      Margin="4,0,0,0"
                                      VerticalAlignment="Center"
                                      Stretch="Fill"
                                      Visibility="Collapsed"/>
                                <!-- Resize gripper -->
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       Width="8"
                                       Cursor="SizeWE">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data"       Value="M 0,5 L 3.5,0 L 7,5 Z"/>
                                <Setter TargetName="SortArrow" Property="Fill"       Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data"       Value="M 0,0 L 3.5,5 L 7,0 Z"/>
                                <Setter TargetName="SortArrow" Property="Fill"       Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="8,0"
                                BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="0,0,0,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2a4d7a"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize"   Value="{StaticResource FontSizeMono}"/>
            <Setter Property="Height"     Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource TableRowHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- barra de status/filtro/exportação -->
            <RowDefinition Height="*"/>    <!-- conteúdo principal -->
        </Grid.RowDefinitions>

        <!-- ── Barra de ferramentas ─────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>    <!-- label filtro -->
                    <ColumnDefinition Width="180"/>     <!-- textbox filtro -->
                    <ColumnDefinition Width="Auto"/>    <!-- contador filtro -->
                    <ColumnDefinition Width="*"/>       <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>    <!-- status + aviso -->
                    <ColumnDefinition Width="Auto"/>    <!-- botões exportação -->
                </Grid.ColumnDefinitions>

                <!-- Filtro -->
                <TextBlock Grid.Column="0"
                           Text="Filtrar:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,6,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>

                <!-- Contador filtro (X de Y) -->
                <TextBlock Grid.Column="2"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           Text="{Binding TextoContadorFiltro}"
                           Visibility="{Binding MostrarContadorFiltro, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Status + aviso de limite -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <TextBlock Text="{Binding StatusTexto}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" ⚠ Limite de linhas atingido — resultado pode estar incompleto"
                               Foreground="{StaticResource StatusWarning}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Visibility="{Binding LimiteAtingido, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>

                <!-- Botões de exportação -->
                <StackPanel Grid.Column="5"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding CopiarTsvCommand}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="10,4"
                            FontSize="11"
                            ToolTip="Copiar para clipboard em formato TSV">
                        Copiar TSV
                    </Button>
                    <Button Command="{Binding ExportarCsvCommand}"
                            Style="{StaticResource ButtonSecondary}"
                            Padding="10,4"
                            FontSize="11"
                            Margin="6,0,0,0"
                            ToolTip="Exportar resultado como arquivo .csv">
                        Exportar CSV
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Área de conteúdo ─────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- DataGrid de resultados -->
            <DataGrid ItemsSource="{Binding DataView}"
                      Visibility="{Binding TemResultado, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Painel de erro -->
            <Border Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibility}}"
                    Background="{StaticResource AppBackground}"
                    Padding="24">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="Erro na execução"
                               Foreground="{StaticResource StatusError}"
                               FontSize="13"
                               FontFamily="{StaticResource FontBase}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding MensagemErro}"
                               Foreground="{StaticResource TextPrimary}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="{StaticResource FontSizeMono}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Estado vazio / inicial -->
            <Border Visibility="{Binding MostrarVazio, Converter={StaticResource BoolToVisibility}}"
                    Background="{StaticResource AppBackground}">
                <TextBlock Text="Execute uma query para ver os resultados."
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
