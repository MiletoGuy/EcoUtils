<UserControl x:Class="EcoUtils.Views.SqlDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:models="clr-namespace:EcoUtils.Models"
             xmlns:views="clr-namespace:EcoUtils.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid>

        <!-- Estado vazio -->
        <Border Visibility="{Binding EntradaDefinida, Converter={StaticResource InverseBoolToVisibility}}"
                Background="{StaticResource AppBackground}">
            <TextBlock Text="Selecione uma consulta na lista"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13"/>
        </Border>

        <!-- Detalhe + resultado -->
        <Grid Visibility="{Binding EntradaDefinida, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- cabeçalho + SQL + ação -->
                <RowDefinition Height="*"/>    <!-- resultado -->
            </Grid.RowDefinitions>

            <!-- ── Cabeçalho ──────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel>

                    <!-- Nome -->
                    <TextBlock Text="{Binding Entrada.Nome}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <!-- Categoria -->
                    <Border Background="#22569cd6"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Entrada.Categoria}"
                                   Foreground="#569cd6"
                                   FontSize="11"/>
                    </Border>

                    <!-- Descrição -->
                    <TextBlock Text="{Binding Entrada.Descricao}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <!-- SQL body -->
                    <TextBlock Text="SQL"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4"/>

                    <TextBox Text="{Binding Entrada.CorpoSql, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             MaxHeight="160"
                             FontFamily="{StaticResource FontMono}"
                             FontSize="{StaticResource FontSizeMono}"
                             Foreground="{StaticResource TextPrimary}"
                             Background="{StaticResource AppBackground}"
                             BorderBrush="{StaticResource PanelBorder}"
                             BorderThickness="1"
                             Padding="8"/>

                    <!-- Parâmetros (visível quando há parâmetros definidos) -->
                    <StackPanel Visibility="{Binding PossuiParametros, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,12,0,0">

                        <TextBlock Text="Parâmetros"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding Parametros}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SqlParameterInstance}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Label: nome + tipo + descrição -->
                                        <StackPanel Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Definicao.Nome}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding Definicao.Tipo}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10"
                                                       Margin="0,1,0,0"/>
                                            <TextBlock Text="{Binding Definicao.Descricao}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.7"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Input -->
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ValorTexto, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalAlignment="Top"
                                                 FontFamily="{StaticResource FontMono}"
                                                 FontSize="{StaticResource FontSizeMono}"
                                                 Foreground="{StaticResource TextPrimary}"
                                                 Background="{StaticResource InputBackground}"
                                                 BorderBrush="{StaticResource PanelBorder}"
                                                 BorderThickness="1"
                                                 Padding="6,4"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Barra de ação -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding ExecutarCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="16,6"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Margin="0,0,6,0" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="Executar"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{Binding EditarCommand}"
                                Style="{StaticResource ButtonSecondary}"
                                Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✎" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Editar"/>
                            </StackPanel>
                        </Button>

                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Resultado ─────────────────────────────────────────────── -->
            <views:SqlResultView Grid.Row="1" DataContext="{Binding ResultadoVM}"/>

        </Grid>
    </Grid>
</UserControl>
