<UserControl x:Class="EcoUtils.Views.SqlDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:views="clr-namespace:EcoUtils.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid>

        <!-- Estado vazio -->
        <Border Visibility="{Binding EntradaDefinida, Converter={StaticResource InverseBoolToVisibility}}"
                Background="{StaticResource AppBackground}">
            <TextBlock Text="Selecione uma consulta na lista"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13"/>
        </Border>

        <!-- Detalhe + resultado -->
        <Grid Visibility="{Binding EntradaDefinida, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- cabeçalho + SQL + ação -->
                <RowDefinition Height="*"/>    <!-- resultado -->
            </Grid.RowDefinitions>

            <!-- ── Cabeçalho ──────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel>

                    <!-- Nome -->
                    <TextBlock Text="{Binding Entrada.Nome}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <!-- Categoria -->
                    <Border Background="#22569cd6"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Entrada.Categoria}"
                                   Foreground="#569cd6"
                                   FontSize="11"/>
                    </Border>

                    <!-- Descrição -->
                    <TextBlock Text="{Binding Entrada.Descricao}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <!-- SQL body -->
                    <TextBlock Text="SQL"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,12,0,4"/>

                    <TextBox Text="{Binding Entrada.CorpoSql, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             MaxHeight="160"
                             FontFamily="{StaticResource FontMono}"
                             FontSize="{StaticResource FontSizeMono}"
                             Foreground="{StaticResource TextPrimary}"
                             Background="{StaticResource AppBackground}"
                             BorderBrush="{StaticResource PanelBorder}"
                             BorderThickness="1"
                             Padding="8"/>

                    <!-- Barra de ação -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding ExecutarCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="16,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Margin="0,0,6,0" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="Executar"/>
                            </StackPanel>
                        </Button>

                        <!-- Aviso de parâmetros pendentes -->
                        <Border Grid.Column="1"
                                Visibility="{Binding PossuiParametros, Converter={StaticResource BoolToVisibility}}"
                                Background="#33ce9178"
                                CornerRadius="3"
                                Padding="8,4"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TextoParametros}"
                                       Foreground="{StaticResource StatusWarning}"
                                       FontSize="11"/>
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Resultado ─────────────────────────────────────────────── -->
            <views:SqlResultView Grid.Row="1" DataContext="{Binding ResultadoVM}"/>

        </Grid>
    </Grid>
</UserControl>
