<UserControl x:Class="EcoUtils.Views.SqlLivreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:EcoUtils.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120"/>  <!-- editor -->
            <RowDefinition Height="Auto"/>               <!-- toolbar executar -->
            <RowDefinition Height="3*"/>                 <!-- resultado -->
        </Grid.RowDefinitions>

        <!-- ── Editor de texto ─────────────────────────────────── -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1">
            <TextBox x:Name="EditorQuery"
                     Text="{Binding TextoQuery, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="{StaticResource FontMono}"
                     FontSize="{StaticResource FontSizeMono}"
                     Background="{StaticResource AppBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderThickness="0"
                     Padding="12,10"
                     SpellCheck.IsEnabled="False"/>
        </Border>

        <!-- ── Barra de ação ────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding ExecutarCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        Padding="14,5"
                        IsDefault="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,6,0" FontSize="11"/>
                        <TextBlock Text="Executar"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Ctrl+Enter"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Resultado ────────────────────────────────────────── -->
        <views:SqlResultView Grid.Row="2"
                             DataContext="{Binding ResultadoVM}"/>
    </Grid>
</UserControl>
