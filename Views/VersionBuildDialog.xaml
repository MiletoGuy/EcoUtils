<Window x:Class="EcoUtils.Views.VersionBuildDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBackground}"
        Width="360">
    <Border BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1"
            Padding="24">
        <StackPanel>
            <TextBlock Text="Informar versão do executável"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="15"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Versão"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="VersaoBox"
                     Margin="0,0,0,12"
                     KeyDown="OnKeyDown"/>

            <TextBlock Text="Build"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="BuildBox"
                     Margin="0,0,0,6"
                     KeyDown="OnKeyDown"/>

            <TextBlock x:Name="ErrorBlock"
                       Foreground="{StaticResource StatusError}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Style="{StaticResource ButtonSecondary}"
                        Margin="0,0,8,0"
                        Click="OnCancelar"/>
                <Button Content="Confirmar"
                        Style="{StaticResource ButtonPrimary}"
                        Click="OnConfirmar"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
