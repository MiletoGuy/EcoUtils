<UserControl x:Class="EcoUtils.Views.ConfiguracoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <StackPanel>
        <!-- Título -->
        <TextBlock Text="Configurações"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="15"
                   Margin="0,0,0,24"/>

        <!-- ── IBExpert ── -->
        <TextBlock Text="IBExpert"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <TextBlock Text="Caminho do executável"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding IbExpertPath, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,6,0"/>
            <Button Grid.Column="1"
                    Content="..."
                    Style="{StaticResource ButtonSecondary}"
                    Padding="10,0"
                    Command="{Binding BrowseIbExpertCommand}"/>
        </Grid>

        <!-- Botões -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="Cancelar"
                    Style="{StaticResource ButtonSecondary}"
                    Command="{Binding CancelarCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Salvar"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding SalvarCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
