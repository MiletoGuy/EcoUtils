<UserControl x:Class="EcoUtils.Views.ExecutarEcoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:models="clr-namespace:EcoUtils.Models"
             xmlns:views="clr-namespace:EcoUtils.Views"
             x:Name="Root"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:BoolToGridLengthConverter x:Key="BoolToColumnWidth"/>

        <!-- Cabeçalho de coluna clicável -->
        <Style x:Key="ColHeader" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Padding"                   Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground"                Value="{StaticResource TextSecondary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Indicador de ordenação: ▲/▼ condicionado a coluna e direção -->
        <Style x:Key="SortIcon" TargetType="TextBlock">
            <Setter Property="Margin"     Value="4,0,0,0"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Text"       Value="&#x25B2;"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="Executar ECO"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="15"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Toolbar: pesquisa + adicionar + configuração de colunas — sempre visível -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,7">
            <DockPanel>
                <!-- Botão de configuração de colunas + Popup (extrema direita) -->
                <Grid DockPanel.Dock="Right" Margin="4,0,0,0">
                    <Button x:Name="BtnConfigColunas"
                            Content="&#x22EE;"
                            Style="{StaticResource ButtonIcon}"
                            Command="{Binding ToggleConfigColunasCommand}"
                            ToolTip="Configurar colunas"
                            Width="28" Height="28"/>
                    <Popup IsOpen="{Binding ConfigColunasAberto, Mode=TwoWay}"
                           StaysOpen="False"
                           PlacementTarget="{Binding ElementName=BtnConfigColunas}"
                           Placement="Bottom"
                           HorizontalOffset="-80">
                        <Border Background="{StaticResource PanelBackground}"
                                BorderBrush="{StaticResource PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Colunas visíveis"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,0,0,8"/>
                                <CheckBox Content="Executável"
                                          Margin="0,0,0,6"
                                          IsChecked="{Binding DataContext.MostrarExecutavel, ElementName=Root}"/>
                                <CheckBox Content="Banco"
                                          Margin="0,0,0,6"
                                          IsChecked="{Binding DataContext.MostrarBanco, ElementName=Root}"/>
                                <CheckBox Content="Versão"
                                          IsChecked="{Binding DataContext.MostrarVersao, ElementName=Root}"/>
                                <CheckBox Content="Versão original"
                                          Margin="0,6,0,0"
                                          IsChecked="{Binding DataContext.MostrarVersaoOriginal, ElementName=Root}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Botão adicionar instância -->
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Style="{StaticResource ButtonPrimary}"
                        Padding="0"
                        Command="{Binding AdicionarCommand}"
                        Width="28" Height="28"
                        Margin="0,0,4,0"/>

                <!-- Caixa de pesquisa -->
                <TextBox Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                         Width="210"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Estado vazio -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding ListaVazia, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Nenhuma instância cadastrada."
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Clique em + para adicionar uma instância ECO."
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Tabela de instâncias -->
        <Grid Grid.Row="2"
              Visibility="{Binding ListaVazia, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho da tabela -->
            <Border Grid.Row="0"
                    Background="{StaticResource TableHeaderBackground}"
                    Padding="16,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition x:Name="HeaderColApelido"    Width="2*" MinWidth="150"/>
                        <ColumnDefinition x:Name="HeaderColExecutavel" Width="0"/>
                        <ColumnDefinition x:Name="HeaderColBanco"      Width="0"/>
                        <ColumnDefinition Width="{Binding MostrarVersao, Converter={StaticResource BoolToColumnWidth}, ConverterParameter=80}"/>
                        <ColumnDefinition Width="{Binding MostrarVersaoOriginal, Converter={StaticResource BoolToColumnWidth}, ConverterParameter=90}"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <!-- Apelido -->
                    <Button Grid.Column="1" Style="{StaticResource ColHeader}"
                            Command="{Binding OrdenarCommand}" CommandParameter="Apelido">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Apelido"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SortIcon}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrdenacaoColuna}" Value="Apelido">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OrdenacaoAscendente}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Executável -->
                    <Button Grid.Column="2" Style="{StaticResource ColHeader}"
                            Command="{Binding OrdenarCommand}" CommandParameter="ExecutavelNome">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Executável"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SortIcon}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrdenacaoColuna}" Value="ExecutavelNome">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OrdenacaoAscendente}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Banco -->
                    <Button Grid.Column="3" Style="{StaticResource ColHeader}"
                            Command="{Binding OrdenarCommand}" CommandParameter="BaseNome">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Banco"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SortIcon}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrdenacaoColuna}" Value="BaseNome">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OrdenacaoAscendente}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Versão -->
                    <Button Grid.Column="4" Style="{StaticResource ColHeader}"
                            Command="{Binding OrdenarCommand}" CommandParameter="VersaoBanco">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Versão"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SortIcon}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrdenacaoColuna}" Value="VersaoBanco">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OrdenacaoAscendente}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Versão original -->
                    <Button Grid.Column="5" Style="{StaticResource ColHeader}"
                            Command="{Binding OrdenarCommand}" CommandParameter="VersaoBancoOriginal">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Versão original"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SortIcon}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OrdenacaoColuna}" Value="VersaoBancoOriginal">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OrdenacaoAscendente}" Value="False">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Status -->
                    <TextBlock Grid.Column="0" Text="Status"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Ações -->
                    <TextBlock Grid.Column="6" Text="Ações"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Splitter Apelido | Executável: visível quando Executável visível -->
                    <GridSplitter Grid.Column="1"
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                  Background="Transparent" Cursor="SizeWE"
                                  ResizeDirection="Columns" ResizeBehavior="CurrentAndNext"
                                  Panel.ZIndex="10"
                                  Visibility="{Binding MostrarExecutavel, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Splitter Executável | Banco: visível quando ambos visíveis -->
                    <GridSplitter Grid.Column="2"
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                  Background="Transparent" Cursor="SizeWE"
                                  ResizeDirection="Columns" ResizeBehavior="CurrentAndNext"
                                  Panel.ZIndex="10"
                                  Visibility="{Binding MostrarSplitterExecutavelBanco, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Separadores visuais de coluna -->
                    <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"/>
                    <Rectangle Grid.Column="2" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"
                               Visibility="{Binding MostrarExecutavel, Converter={StaticResource BoolToVisibility}}"/>
                    <Rectangle Grid.Column="3" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"
                               Visibility="{Binding MostrarBanco, Converter={StaticResource BoolToVisibility}}"/>
                    <Rectangle Grid.Column="4" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"
                               Visibility="{Binding MostrarVersao, Converter={StaticResource BoolToVisibility}}"/>
                    <Rectangle Grid.Column="5" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"
                               Visibility="{Binding MostrarVersaoOriginal, Converter={StaticResource BoolToVisibility}}"/>
                    <Rectangle Grid.Column="6" Width="1" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                               Fill="{StaticResource PanelBorder}" Opacity="0.5"/>
                </Grid>
            </Border>

            <!-- Linhas -->
            <ListBox x:Name="ListaInstancias"
                     Grid.Row="1"
                     Background="{StaticResource AppBackground}"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ItemsSource="{Binding InstanciasView}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Tag" Value="{Binding DataContext, ElementName=ListaInstancias}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="▶  Executar"
                                              Command="{Binding PlacementTarget.Tag.ExecutarCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Style>
                                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.EstaRestaurando, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </MenuItem.Style>
                                    </MenuItem>
                                    <MenuItem Header="✎  Editar"
                                              Command="{Binding PlacementTarget.Tag.EditarCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="⧉  Copiar caminho da base"
                                              Command="{Binding PlacementTarget.Tag.CopiarCaminhoBaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator Style="{StaticResource ContextMenuSeparator}"/>
                                    <MenuItem Header="✕  Excluir"
                                              Style="{StaticResource MenuItemDanger}"
                                              Command="{Binding PlacementTarget.Tag.ExcluirCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="16,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="{Binding DataContext.ColWidthApelido,    ElementName=Root}"/>
                                <ColumnDefinition Width="{Binding DataContext.ColWidthExecutavel, ElementName=Root}"/>
                                <ColumnDefinition Width="{Binding DataContext.ColWidthBanco,      ElementName=Root}"/>
                                <ColumnDefinition Width="{Binding DataContext.MostrarVersao, ElementName=Root, Converter={StaticResource BoolToColumnWidth}, ConverterParameter=80}"/>
                                <ColumnDefinition Width="{Binding DataContext.MostrarVersaoOriginal, ElementName=Root, Converter={StaticResource BoolToColumnWidth}, ConverterParameter=90}"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Apelido}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ExecutavelNome}"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding BaseNome}"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4"
                                       Text="{Binding VersaoBanco}"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5"
                                       Text="{Binding VersaoBancoOriginal}"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <!-- Status de restauração / incompatibilidade -->
                            <Grid Grid.Column="0"
                                  Width="40"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">

                                <!-- Restaurando: spinner animado -->
                                <Ellipse Width="16" Height="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Stroke="{StaticResource ButtonPrimaryBackground}"
                                         StrokeThickness="2"
                                         StrokeDashArray="10 5"
                                         RenderTransformOrigin="0.5,0.5"
                                         Visibility="{Binding EstaRestaurando, Converter={StaticResource BoolToVisibility}}">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.Angle"
                                                        From="0" To="360"
                                                        Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                    <Ellipse.ToolTip>
                                        <ToolTip Content="{Binding UltimaMensagemRestauracao}"/>
                                    </Ellipse.ToolTip>
                                </Ellipse>

                                <!-- Concluído -->
                                <TextBlock Text="&#x2713;"
                                           Foreground="{StaticResource StatusSuccess}"
                                           FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           ToolTip="Restauração concluída"
                                           Visibility="{Binding RestauracaoConcluida, Converter={StaticResource BoolToVisibility}}"/>

                                <!-- Falhou (restauração) -->
                                <TextBlock Text="&#x2715;"
                                           Foreground="{StaticResource StatusError}"
                                           FontSize="12" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding RestauracaoFalhou, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="{Binding ErroRestauracao}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>

                                <!-- Versão incompatível (somente quando não há status de restauração) -->
                                <TextBlock Text="&#x26A0;"
                                           Foreground="{StaticResource StatusWarning}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           ToolTip="Versão do banco incompatível com o executável selecionado.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding VersaoIncompativel}" Value="True"/>
                                                        <Condition Binding="{Binding EstaRestaurando}"    Value="False"/>
                                                        <Condition Binding="{Binding RestauracaoConcluida}" Value="False"/>
                                                        <Condition Binding="{Binding RestauracaoFalhou}"  Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Versão do banco alterada pelo Utils -->
                                <TextBlock Text="&#x270E;"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource ButtonPrimaryBackground}"
                                           ToolTip="Versão do banco foi forçada para corresponder ao executável.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding VersaoBancoAlterada}"  Value="True"/>
                                                        <Condition Binding="{Binding VersaoIncompativel}"   Value="False"/>
                                                        <Condition Binding="{Binding EstaRestaurando}"      Value="False"/>
                                                        <Condition Binding="{Binding RestauracaoConcluida}" Value="False"/>
                                                        <Condition Binding="{Binding RestauracaoFalhou}"    Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel Grid.Column="6"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="&#x25B6;"
                                        Command="{Binding DataContext.ExecutarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,4,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ButtonIcon}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EstaRestaurando}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="ToolTip" Value="Aguardando restauração da base..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="&#x270E;"
                                        Style="{StaticResource ButtonIcon}"
                                        Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,4,0"/>
                                <Button Content="&#x2715;"
                                        Style="{StaticResource ButtonDanger}"
                                        Width="20" Height="20"
                                        VerticalAlignment="Center"
                                        Padding="0"
                                        FontSize="9"
                                        FontWeight="Bold"
                                        Command="{Binding DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Flyout overlay (cobre toda a área) -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding FlyoutAberto, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="{StaticResource OverlayBackground}"/>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="480"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
                <views:InstanceFlyoutView DataContext="{Binding FlyoutVM}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
