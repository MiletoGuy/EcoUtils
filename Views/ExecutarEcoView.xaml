<UserControl x:Class="EcoUtils.Views.ExecutarEcoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EcoUtils.Converters"
             xmlns:views="clr-namespace:EcoUtils.Views">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackground}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding AdicionarCommand}"
                        Width="28" Height="28"/>
                <TextBlock Text="Executar ECO"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="15"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Estado vazio -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding ListaVazia, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Nenhuma instância cadastrada."
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Clique em + para adicionar uma instância ECO."
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Tabela de instâncias -->
        <Grid Grid.Row="1"
              Visibility="{Binding ListaVazia, Converter={StaticResource InverseBoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho da tabela -->
            <Border Grid.Row="0"
                    Background="{StaticResource TableHeaderBackground}"
                    Padding="16,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Apelido"    Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Grid.Column="1" Text="Executável" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Grid.Column="2" Text="Banco"      Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Grid.Column="3" Text="Ações"      Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </Border>

            <!-- Linhas -->
            <ListBox Grid.Row="1"
                     Background="{StaticResource AppBackground}"
                     BorderThickness="0"
                     ItemsSource="{Binding Instancias}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Apelido}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ExecutavelNome}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding BaseNome}"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="▶"
                                        Style="{StaticResource ButtonIcon}"
                                        Command="{Binding DataContext.ExecutarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,4,0"/>
                                <Button Content="✎"
                                        Style="{StaticResource ButtonIcon}"
                                        Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,4,0"/>
                                <Button Content="✕"
                                        Style="{StaticResource ButtonDanger}"
                                        Command="{Binding DataContext.ExcluirCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Flyout overlay (cobre toda a área) -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding FlyoutAberto, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="{StaticResource OverlayBackground}"/>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="480"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
                <views:InstanceFlyoutView DataContext="{Binding FlyoutVM}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
