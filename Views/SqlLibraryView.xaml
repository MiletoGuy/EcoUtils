<UserControl x:Class="EcoUtils.Views.SqlLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:EcoUtils.Models"
             xmlns:views="clr-namespace:EcoUtils.Views">

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264"/>  <!-- painel esquerdo: lista -->
            <ColumnDefinition Width="1"/>    <!-- separador -->
            <ColumnDefinition Width="*"/>    <!-- painel direito: detalhe -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             Painel esquerdo — lista de SQLs
        ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{StaticResource PanelBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- busca + filtro de categoria -->
                <RowDefinition Height="*"/>     <!-- lista agrupada -->
            </Grid.RowDefinitions>

            <!-- Busca + Categoria -->
            <StackPanel Grid.Row="0"
                        Margin="10,10,10,6">

                <TextBox Text="{Binding TextoBusca, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{StaticResource TextPrimary}"
                         Background="{StaticResource InputBackground}"
                         BorderBrush="{StaticResource PanelBorder}"
                         BorderThickness="1"
                         FontFamily="{StaticResource FontBase}"
                         FontSize="{StaticResource FontSizeBase}"
                         Padding="8,5"
                         Margin="0,0,0,6">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Background"  Value="{StaticResource InputBackground}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <ComboBox ItemsSource="{Binding Categorias}"
                          SelectedItem="{Binding CategoriaFiltro}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background"      Value="{StaticResource InputBackground}"/>
                            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                            <Setter Property="BorderBrush"     Value="{StaticResource PanelBorder}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontFamily"      Value="{StaticResource FontBase}"/>
                            <Setter Property="FontSize"        Value="{StaticResource FontSizeBase}"/>
                            <Setter Property="Padding"         Value="8,4"/>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
            </StackPanel>

            <!-- Lista agrupada -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding EntradasView}"
                     SelectedItem="{Binding EntradaSelecionada}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <!-- Estilo do item -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"     Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A569cd6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0FFFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- Template de cada item -->
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:SqlEntry}">
                        <StackPanel Margin="12,5,8,5">
                            <TextBlock Text="{Binding Nome}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="12"
                                       FontFamily="{StaticResource FontBase}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Descricao}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       FontFamily="{StaticResource FontBase}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Agrupamento por categoria -->
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <!-- Cabeçalho do grupo -->
                                                <Border Background="#1A000000"
                                                        Padding="12,5,8,5"
                                                        BorderBrush="{StaticResource PanelBorder}"
                                                        BorderThickness="0,1,0,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               FontFamily="{StaticResource FontBase}"/>
                                                </Border>
                                                <!-- Itens do grupo -->
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>
        </Grid>

        <!-- Separador vertical -->
        <Rectangle Grid.Column="1"
                   Fill="{StaticResource PanelBorder}"/>

        <!-- ═══════════════════════════════════════════════════════
             Painel direito — detalhe
        ═══════════════════════════════════════════════════════ -->
        <views:SqlDetailView Grid.Column="2"
                             DataContext="{Binding DetalheVM}"/>
    </Grid>
</UserControl>
