<UserControl x:Class="EcoUtils.Views.InstanceFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <StackPanel>
        <!-- Título -->
        <TextBlock Text="{Binding Titulo}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="15"
                   Margin="0,0,0,20"/>

        <!-- Apelido -->
        <TextBlock Text="Apelido"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <TextBox Text="{Binding Apelido, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,4"/>
        <TextBlock Text="Apelido já está em uso."
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   Margin="0,0,0,12"
                   Visibility="{Binding ApelidoDuplicado, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Banco de Dados -->
        <TextBlock Text="Banco de Dados"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Bancos}"
                      SelectedItem="{Binding BancoSelecionado}"
                      DisplayMemberPath="NomeCompleto"
                      IsEnabled="{Binding NaoImportando}"/>
            <Button Grid.Column="1"
                    Content="+"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding AdicionarBancoCommand}"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    ToolTip="Importar banco de dados"/>
        </Grid>

        <!-- Progresso de importação -->
        <StackPanel Visibility="{Binding IsImportandoBanco, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,4">
            <TextBlock Text="{Binding MensagemProgresso}"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressoImportacao, Mode=OneWay}"
                         IsIndeterminate="{Binding IsIndeterminadaImportacao}"
                         Maximum="100"
                         Height="4"/>
        </StackPanel>

        <!-- Erro de importação -->
        <TextBlock Text="{Binding ErroImportacao}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Visibility="{Binding TemErroImportacao, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Versão do banco (exibida assim que banco é selecionado) -->
        <TextBlock Text="{Binding StatusBancoVersao}"
                   FontSize="11"
                   Margin="0,0,0,16"
                   Foreground="{StaticResource TextSecondary}"/>

        <!-- Executável ECO -->
        <TextBlock Text="Executável ECO"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Executaveis}"
                      SelectedItem="{Binding ExecutavelSelecionado}"
                      DisplayMemberPath="NomeCompleto"
                      IsEnabled="{Binding NaoImportandoExe}"/>
            <Button Grid.Column="1"
                    Content="+"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding AdicionarExeCommand}"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    ToolTip="Importar executável ECO"/>
        </Grid>

        <!-- Progresso de importação de executável -->
        <StackPanel Visibility="{Binding IsImportandoExe, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,4">
            <TextBlock Text="{Binding MensagemProgressoExe}"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressoExe, Mode=OneWay}"
                         Maximum="100"
                         Height="4"/>
        </StackPanel>

        <!-- Erro de importação de executável -->
        <TextBlock Text="{Binding ErroImportacaoExe}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"
                   Visibility="{Binding TemErroImportacaoExe, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Status eco.ini -->
        <TextBlock Text="{Binding StatusIni}"
                   FontSize="11"
                   Margin="0,0,0,6">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource StatusSuccess}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Compatibilidade de versão banco × executável -->
        <TextBlock Text="{Binding StatusVersao}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding VersaoCompativel}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource StatusSuccess}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding VersaoCompativel}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusWarning}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Erro de confirmação -->
        <TextBlock Text="{Binding ErroConfirmacao}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Botões -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Style="{StaticResource ButtonSecondary}"
                    Command="{Binding CancelarCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="{Binding TextoBotaoConfirmar}"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding ConfirmarCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
