<UserControl x:Class="EcoUtils.Views.InstanceFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <StackPanel>
        <!-- Título -->
        <TextBlock Text="{Binding Titulo}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="15"
                   Margin="0,0,0,20"/>

        <!-- Apelido -->
        <TextBlock Text="Apelido"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <TextBox Text="{Binding Apelido, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,4"/>
        <TextBlock Text="Apelido já está em uso."
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   Margin="0,0,0,12"
                   Visibility="{Binding ApelidoDuplicado, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Banco de Dados -->
        <TextBlock Text="Banco de Dados"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Bancos}"
                      SelectedItem="{Binding BancoSelecionado}"
                      DisplayMemberPath="NomeCompleto"
                      IsEnabled="{Binding NaoImportando}"/>
            <Button Grid.Column="1"
                    Content="+"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding AdicionarBancoCommand}"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    ToolTip="Importar banco de dados"/>
        </Grid>

        <!-- Progresso de importação -->
        <StackPanel Visibility="{Binding IsImportandoBanco, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,4">
            <TextBlock Text="{Binding MensagemProgresso}"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressoImportacao, Mode=OneWay}"
                         IsIndeterminate="{Binding IsIndeterminadaImportacao}"
                         Maximum="100"
                         Height="4"/>
        </StackPanel>

        <!-- Erro de importação -->
        <TextBlock Text="{Binding ErroImportacao}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Visibility="{Binding TemErroImportacao, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Versão do banco (exibida assim que banco é selecionado) -->
        <TextBlock Text="{Binding StatusBancoVersao}"
                   FontSize="11"
                   Margin="0,0,0,8"
                   Foreground="{StaticResource TextSecondary}"/>

        <!-- Aviso: base em restauração ativa -->
        <Border Background="{StaticResource InputBackground}"
                BorderBrush="{StaticResource InputBorder}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="10,8"
                Margin="0,0,0,16"
                Visibility="{Binding BaseEmRestauracao, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Botão Cancelar Restauração / spinner de carregamento -->
                <Grid DockPanel.Dock="Right" Margin="8,0,0,0" VerticalAlignment="Top">
                    <Button Content="Cancelar Restauração"
                            Style="{StaticResource ButtonDangerOutline}"
                            Padding="8,4"
                            Command="{Binding CancelarRestauracaoFlyoutCommand}"
                            Visibility="{Binding IsCancellingRestauracao, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsCancellingRestauracao, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="80" Height="4"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>
                        <TextBlock Text="Cancelando..."
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <StackPanel>
                    <TextBlock Text="Esta base está sendo restaurada em segundo plano."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding MensagemRestauracao}"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Height="28"
                               Opacity="0.7"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Executável ECO -->
        <TextBlock Text="Executável ECO"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Labels -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Major"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,4"/>
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Versão"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,4"/>
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Build"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <!-- ComboBox de major -->
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding MajorsSelecionaveis}"
                      SelectedItem="{Binding MajorSelecionado}"
                      IsEnabled="{Binding NaoImportandoExe}"
                      Margin="0,0,0,4"/>

            <!-- ComboBox de versão -->
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding VersoesSelecionaveis}"
                      SelectedItem="{Binding VersaoSelecionada}"
                      IsEnabled="{Binding PodeSelecionarVersao}"
                      Margin="0,0,0,4"/>

            <!-- ComboBox de build -->
            <ComboBox Grid.Row="2" Grid.Column="1"
                      ItemsSource="{Binding BuildsSelecionaveis}"
                      SelectedItem="{Binding ExecutavelSelecionado}"
                      DisplayMemberPath="NumeroBuild"
                      IsEnabled="{Binding PodeSelecionarBuild}"/>

            <!-- Botão importar (alinhado ao centro vertical das três linhas) -->
            <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                    Content="+"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding AdicionarExeCommand}"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Importar executável ECO"/>
        </Grid>

        <!-- Progresso de importação de executável -->
        <StackPanel Visibility="{Binding IsImportandoExe, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,4">
            <TextBlock Text="{Binding MensagemProgressoExe}"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"/>
            <ProgressBar Value="{Binding ProgressoExe, Mode=OneWay}"
                         Maximum="100"
                         Height="4"/>
        </StackPanel>

        <!-- Hint: executável será auto-selecionado após restauração -->
        <TextBlock Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   Visibility="{Binding AguardandoExeAutoSelecionado, Converter={StaticResource BoolToVisibility}}"
                   Text="O executável compatível com major e versão da base será selecionado automaticamente ao término da restauração (maior build disponível)."/>

        <!-- Erro de importação de executável -->
        <TextBlock Text="{Binding ErroImportacaoExe}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6"
                   Visibility="{Binding TemErroImportacaoExe, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Status eco.ini -->
        <TextBlock Text="{Binding StatusIni}"
                   FontSize="11"
                   Margin="0,0,0,6">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource StatusSuccess}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Compatibilidade de versão banco × executável -->
        <TextBlock Text="{Binding StatusVersao}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding VersaoCompativel}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource StatusSuccess}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding VersaoCompativel}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusWarning}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Usar versão do executável -->
        <CheckBox Content="Usar versão do executável"
                  IsChecked="{Binding UsarVersaoExecutavel}"
                  IsEnabled="{Binding PodeAlterarUsarVersaoExecutavel}"
                  Foreground="{StaticResource TextPrimary}"
                  Margin="0,0,0,4"/>

        <!-- Restaurar versão original (somente em modo edição, quando versão foi alterada) -->
        <Button Content="Restaurar versão original"
                Style="{StaticResource ButtonDangerOutline}"
                HorizontalAlignment="Left"
                Padding="8,4"
                Margin="0,4,0,16"
                Command="{Binding RestaurarVersaoOriginalCommand}"
                Visibility="{Binding PodeRestaurarVersaoOriginal, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Versão do Firebird -->
        <TextBlock Text="Versão do Firebird"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,12,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton Content="Firebird 2.5"
                         IsChecked="{Binding VersaoFirebird25, Mode=TwoWay}"
                         Foreground="{StaticResource TextPrimary}"
                         Margin="0,0,16,0"/>
            <RadioButton Content="Firebird 5.0"
                         IsChecked="{Binding VersaoFirebird50, Mode=TwoWay}"
                         Foreground="{StaticResource TextPrimary}"/>
        </StackPanel>

        <!-- Configurações do .ini — cabeçalho colapsável -->
        <Button Command="{Binding ToggleIniExpandedCommand}"
                BorderThickness="0"
                Padding="0"
                Cursor="Hand"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Margin="0,0,0,0">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="▸ Configurações do .ini"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IniExpanded}" Value="True">
                                    <Setter Property="Text" Value="▾ Configurações do .ini"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Rectangle Grid.Column="1"
                           Height="1"
                           Fill="{StaticResource InputBorder}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>
            </Grid>
        </Button>

        <StackPanel Visibility="{Binding IniExpanded, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,10,0,0">

            <!-- Título da seção -->
            <TextBlock Text="[PREFERENCIAS]"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <!-- Usuário — label e input na mesma linha -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Usuário"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <CheckBox Content="PesquisaTotalDosProdutos"
                      IsChecked="{Binding PesquisaTotalDosProdutos}"
                      Foreground="{StaticResource TextPrimary}"
                      Margin="0,0,0,4"/>
            <CheckBox Content="MonitorarTempoSelects"
                      IsChecked="{Binding MonitorarTempoSelects}"
                      Foreground="{StaticResource TextPrimary}"
                      Margin="0,0,0,4"/>
            <CheckBox Content="SincronizaTabelaPreco"
                      IsChecked="{Binding SincronizaTabelaPreco}"
                      Foreground="{StaticResource TextPrimary}"
                      Margin="0,0,0,4"/>
            <CheckBox Content="MultiplasInstancias"
                      IsChecked="{Binding MultiplasInstancias}"
                      Foreground="{StaticResource TextPrimary}"
                      Margin="0,0,0,16"/>
        </StackPanel>

        <!-- Erro de confirmação -->
        <TextBlock Text="{Binding ErroConfirmacao}"
                   Foreground="{StaticResource StatusError}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="{Binding TemErro, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Botões -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Style="{StaticResource ButtonSecondary}"
                    Command="{Binding CancelarCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="{Binding TextoBotaoConfirmar}"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding ConfirmarCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
