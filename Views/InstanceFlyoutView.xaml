<UserControl x:Class="EcoUtils.Views.InstanceFlyoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <StackPanel>
        <!-- Título -->
        <TextBlock Text="{Binding Titulo}"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="15"
                   Margin="0,0,0,20"/>

        <!-- Apelido -->
        <TextBlock Text="Apelido"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <TextBox Text="{Binding Apelido, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,16"/>

        <!-- Executável -->
        <TextBlock Text="Executável ECO"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding Executaveis}"
                  SelectedItem="{Binding ExecutavelSelecionado}"
                  DisplayMemberPath="NomeCompleto"
                  Margin="0,0,0,6"/>

        <!-- Status eco.ini -->
        <TextBlock Text="{Binding StatusIni}"
                   FontSize="11"
                   Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource StatusSuccess}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding EcoIniValido}" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource StatusError}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Banco de Dados -->
        <TextBlock Text="Banco de Dados"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding Bancos}"
                  SelectedItem="{Binding BancoSelecionado}"
                  DisplayMemberPath="NomeCompleto"
                  Margin="0,0,0,24"/>

        <!-- Botões -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Style="{StaticResource ButtonSecondary}"
                    Command="{Binding CancelarCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="{Binding TextoBotaoConfirmar}"
                    Style="{StaticResource ButtonPrimary}"
                    Command="{Binding ConfirmarCommand}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
