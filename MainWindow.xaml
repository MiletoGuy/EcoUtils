<Window x:Class="EcoUtils.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:EcoUtils.Views"
        mc:Ignorable="d"
        Title="EcoUtils"
        Icon="Assets/Utils_icon.ico"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox Grid.Row="0"
                     Background="Transparent"
                     ItemsSource="{Binding Abas}"
                     SelectedItem="{Binding AbaAtiva}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,0">
                            <TextBlock Text="{Binding Icone}" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="{Binding Rotulo}"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Botão de configurações na parte inferior -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="0,1,0,0">
                <Button Command="{Binding AbrirConfigCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SidebarItemHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" Margin="0,0,8,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="Configurações"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- Workspace -->
        <Grid Grid.Column="1">
            <ContentControl Content="{Binding AbaAtiva.ViewModel}"/>

            <!-- Ícone de status de atualização (topo direito) -->
            <Grid HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,8,10,0" Width="28" Height="28">

                <!-- Verificando: spinner giratório cinza -->
                <Border CornerRadius="4" Cursor="Hand"
                        ToolTip="Buscando atualizações..."
                        Visibility="{Binding EstaVerificando, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ButtonSecondaryHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Ellipse Width="16" Height="16"
                             Stroke="{StaticResource TextSecondary}"
                             StrokeThickness="2"
                             StrokeDashArray="6 19"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
                        <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Border>

                <!-- Sem atualização: checkmark -->
                <Border CornerRadius="4" Cursor="Hand"
                        ToolTip="Não há novas atualizações"
                        Visibility="{Binding SemAtualizacao, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ButtonSecondaryHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource StatusSuccess}"/>
                </Border>

                <!-- Atualização disponível: botão de download -->
                <Button Command="{Binding AtualizarCommand}"
                        Style="{StaticResource ButtonIcon}"
                        ToolTip="Atualizar agora"
                        Width="28" Height="28" Padding="2"
                        Visibility="{Binding TemAtualizacao, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="⭳" FontSize="17"
                               Foreground="{StaticResource ButtonPrimaryBackground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Atualizando: spinner azul -->
                <Border CornerRadius="4" Cursor="Hand"
                        ToolTip="Baixando atualização..."
                        Visibility="{Binding EstaAtualizando, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ButtonSecondaryHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Ellipse Width="16" Height="16"
                             Stroke="{StaticResource ButtonPrimaryBackground}"
                             StrokeThickness="2"
                             StrokeDashArray="6 19"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
                        <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                            From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </Border>

            </Grid>
        </Grid>

        <!-- Overlay de configurações (cobre toda a janela) -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2"
              Visibility="{Binding ConfigAberto, Converter={StaticResource BoolToVisibility}}">
            <Rectangle Fill="{StaticResource OverlayBackground}">
                <Rectangle.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ConfiguracoesVM.CancelarCommand}"/>
                </Rectangle.InputBindings>
            </Rectangle>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="700"
                    Height="480"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="4">
                <views:ConfiguracoesView DataContext="{Binding ConfiguracoesVM}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
