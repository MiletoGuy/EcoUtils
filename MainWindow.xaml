<Window x:Class="EcoUtils.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EcoUtils"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <ListBox Grid.Column="0"
                 Background="{StaticResource SidebarBackground}"
                 ItemsSource="{Binding Abas}"
                 SelectedItem="{Binding AbaAtiva}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <TextBlock Text="{Binding Icone}" Margin="0,0,8,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="{Binding Rotulo}"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Workspace -->
        <Grid Grid.Column="1">
            <ContentControl Content="{Binding AbaAtiva.ViewModel}"/>

            <!-- Ícone de status de atualização (topo direito) -->
            <Grid HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,10,14,0" Width="22" Height="22">

                <!-- Verificando: spinner giratório -->
                <Ellipse Width="16" Height="16"
                         Stroke="{StaticResource TextSecondary}"
                         StrokeThickness="2"
                         StrokeDashArray="6 19"
                         ToolTip="Buscando atualizações..."
                         Visibility="{Binding EstaVerificando, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
                    <Ellipse.RenderTransform>
                        <RotateTransform/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstaVerificando}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    From="0" To="360" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Sem atualização: checkmark -->
                <TextBlock Text="✓"
                           FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource StatusSuccess}"
                           ToolTip="Não há novas atualizações"
                           Visibility="{Binding SemAtualizacao, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Atualização disponível: botão de download -->
                <Button Command="{Binding AtualizarCommand}"
                        Style="{StaticResource ButtonIcon}"
                        ToolTip="Atualizar agora"
                        Width="22" Height="22"
                        Padding="2"
                        Visibility="{Binding TemAtualizacao, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="⬇"
                               FontSize="13"
                               Foreground="{StaticResource ButtonPrimaryBackground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Atualizando: spinner azul -->
                <Ellipse Width="16" Height="16"
                         Stroke="{StaticResource ButtonPrimaryBackground}"
                         StrokeThickness="2"
                         StrokeDashArray="6 19"
                         ToolTip="Baixando atualização..."
                         Visibility="{Binding EstaAtualizando, Converter={StaticResource BoolToVisibility}}">
                    <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
                    <Ellipse.RenderTransform>
                        <RotateTransform/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EstaAtualizando}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    From="0" To="360" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

            </Grid>
        </Grid>
    </Grid>
</Window>
