<Window x:Class="EcoUtils.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EcoUtils.ViewModels"
        mc:Ignorable="d"
        Title="EcoUtils"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="520">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <ListBox Grid.Column="0"
                 Background="{StaticResource SidebarBackground}"
                 ItemsSource="{Binding Abas}"
                 SelectedItem="{Binding AbaAtiva}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <TextBlock Text="{Binding Icone}" Margin="0,0,8,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text="{Binding Rotulo}"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Workspace -->
        <ContentControl Grid.Column="1"
                        Content="{Binding AbaAtiva.ViewModel}"/>
    </Grid>
</Window>
